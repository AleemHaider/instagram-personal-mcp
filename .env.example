# Required: Instagram credentials for the personal account you want to drive.
# STRONGLY recommended: use a secondary / burner account, not your primary.
IG_USERNAME=your_instagram_username
IG_PASSWORD=your_instagram_password

# Optional: where to persist the logged-in session.
# Default: ~/.config/instagram-personal-mcp/session.json
# IG_SESSION_PATH=/home/you/.config/instagram-personal-mcp/session.json

# Optional: device fingerprint to keep stable across runs (instagrapi will
# generate one automatically if unset, and store it in the session file).
# IG_DEVICE_ID=
